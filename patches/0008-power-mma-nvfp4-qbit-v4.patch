+        sc[s] = ue4m3_to_fp32(b->d[s]);
+        for (int j = 0; j < 8; j++) {
+            code[16*s + j + 0] = nvfp4_kvalues[b->qs[8*s + j] & 0xF];
+            code[16*s + j + 8] = nvfp4_kvalues[b->qs[8*s + j] >>  4];
+        }
+    }
