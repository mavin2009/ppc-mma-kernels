+extern "C" void grid16_repack_iq2_xs(const block_iq2_xs_ppc * A, int64_t lda, int64_t m, int64_t k, void * p) {
+    repack_grid16<block_iq2_xs_ppc, dec16_iq2_xs>(A, lda, m, k, (agrid16_t *)p); }
